# Normalize line endings to LF for all text files
* text=auto eol=lf

# Explicitly binary files — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.pyc binary
*.pptx binary
*.docx binary
*.xlsx binary
*.mp3 binary
*.mp4 binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
