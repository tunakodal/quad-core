# ─────────────────────────────────────────────────
# GUIDE API — Environment Variables
# Copy this file to `.env` and fill in the values:
# cp .env.example .env
# ─────────────────────────────────────────────────


# ── Database ──────────────────────────────────────
# PostgreSQL connection string.
# Can be left empty if using JSON stub (fallback mode).
# Example: postgresql+asyncpg://user:pass@localhost:5432/guide
DATABASE_URL=


# ── OSRM Routing Engine ───────────────────────────
# Base URL of the local OSRM instance.
OSRM_BASE_URL=http://localhost:5000

# Timeout for OSRM requests (in milliseconds).
OSRM_TIMEOUT_MS=5000


# ── Media ─────────────────────────────────────────
# Root directory for storing images and audio files.
MEDIA_ROOT_PATH=./media


# ── Trip Planning Limits ──────────────────────────
# Maximum number of trip days (1–10).
MAX_TRIP_DAYS=10

# Maximum number of POIs per day.
MAX_POIS_PER_DAY=9

# Maximum total POIs (max_trip_days × max_pois_per_day).
MAX_TOTAL_POIS=90

# Minimum daily route distance (in meters).
MIN_DAILY_DISTANCE_METERS=1000

# Maximum number of selectable categories.
MAX_CATEGORY_COUNT=10

# Baseline POI count used in day estimation logic.
POIS_PER_DAY_BASELINE=3