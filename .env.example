# ─────────────────────────────────────────────────
#  GUIDE API — Environment Variables
#  Kopyala: cp .env.example .env  (sonra değerleri doldur)
# ─────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────
# Supabase proje URL'i (Settings → API → Project URL)
SUPABASE_URL=https://xxx.supabase.co

# Supabase anon/publishable key (Settings → API → anon/public)
# JSON stub kullanılırken boş bırakılabilir.
SUPABASE_KEY=

# ── OSRM Routing Engine ───────────────────────────
# Yerel OSRM instance'ının adresi.
OSRM_BASE_URL=http://localhost:5000

# OSRM isteklerinde timeout süresi (ms).
OSRM_TIMEOUT_MS=5000

# ── Media ─────────────────────────────────────────
# Görseller ve ses dosyalarının tutulduğu klasör yolu.
MEDIA_ROOT_PATH=./media

# ── Trip Planning Limits ──────────────────────────
# Maksimum gün sayısı (1–10).
MAX_TRIP_DAYS=10

# Günde maksimum POI sayısı.
MAX_POIS_PER_DAY=9

# Toplam maksimum POI sayısı (max_trip_days × max_pois_per_day).
MAX_TOTAL_POIS=90

# Günlük minimum mesafe (metre).
MIN_DAILY_DISTANCE_METERS=1000

# Maksimum kategori seçim sayısı.
MAX_CATEGORY_COUNT=10

# Gün önerisi hesabında baz POI sayısı.
POIS_PER_DAY_BASELINE=3
